<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель управления - NowkeArt</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">NowkeArt</div>
        <div class="nav-links">
            <a href="/dashboard">Главная</a>
            <a href="/services">Услуги</a>
            <a href="/order/new">Новый заказ</a>
            <a href="/help">Помощь</a>
            <a href="/profile">Профиль</a>
            <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
                <a href="/admin" class="admin-link">Админ-панель</a>
            <% } %>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Добро пожаловать, <%= username %>!</h1>
        
        <% if (req.query.order_created) { %>
            <div class="success">Заказ успешно создан! Номер заказа: <%= req.query.order_created %></div>
        <% } %>

        <div class="dashboard-grid">
            <div class="card">
                <h3>Мои заказы</h3>
                <p>Всего заказов: <%= user.orders %></p>
                <a href="#orders" class="btn btn-secondary">Посмотреть все</a>
            </div>
            
            <div class="card">
                <h3>Баланс</h3>
                <p class="balance"><%= user.balance %> ₽</p>
                <a href="/profile" class="btn btn-secondary">Пополнить</a>
            </div>
            
            <div class="card">
                <h3>Создать заказ</h3>
                <p>Оформите новый заказ на наши услуги</p>
                <a href="/order/new" class="btn btn-primary">Создать</a>
            </div>
        </div>

        <section id="orders" class="orders-section">
            <h2>Мои заказы</h2>
            <% if (orders.length > 0) { %>
                <table class="orders-table">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>Услуга</th>
                            <th>Статус</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td>#<%= order.number %></td>
                                <td><%= order.service %></td>
                                <td><span class="status status-<%= order.status.replace(/\s/g, '-') %>"><%= order.status %></span></td>
                                <td><%= new Date(order.created_at).toLocaleDateString('ru-RU') %></td>
                                <td><a href="/order/<%= order.id %>" class="btn btn-small">Просмотр</a></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p>У вас пока нет заказов. <a href="/order/new">Создайте первый заказ!</a></p>
            <% } %>
        </section>
    </div>
</body>
</html>
