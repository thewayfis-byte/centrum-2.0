<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Управление заказами - Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-admin">
        <div class="nav-brand">NowkeArt Admin</div>
        <div class="nav-links">
            <a href="/admin">Главная</a>
            <a href="/admin/orders">Заказы</a>
            <a href="/admin/users">Пользователи</a>
            <a href="/admin/staff">Сотрудники</a>
            <a href="/admin/services">Услуги</a>
            <a href="/admin/promocodes">Промокоды</a>
            <a href="/admin/settings">Настройки</a>
            <a href="/dashboard">На сайт</a>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Управление заказами</h1>
        
        <div class="filter-tabs">
            <a href="/admin/orders?filter=all" class="tab <%= filter === 'all' ? 'active' : '' %>">Все</a>
            <a href="/admin/orders?filter=pending" class="tab <%= filter === 'pending' ? 'active' : '' %>">В ожидании</a>
            <a href="/admin/orders?filter=in_progress" class="tab <%= filter === 'in_progress' ? 'active' : '' %>">В работе</a>
            <a href="/admin/orders?filter=completed" class="tab <%= filter === 'completed' ? 'active' : '' %>">Завершенные</a>
        </div>

        <table class="orders-table">
            <thead>
                <tr>
                    <th>№</th>
                    <th>Пользователь</th>
                    <th>Услуга</th>
                    <th>Статус</th>
                    <th>Дизайнер</th>
                    <th>Менеджер</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order => { %>
                    <tr>
                        <td>#<%= order.number %></td>
                        <td>@id<%= order.user_id %></td>
                        <td><%= order.service %></td>
                        <td>
                            <form action="/admin/order/<%= order.id %>/status" method="POST" style="display: inline;">
                                <select name="status" onchange="this.form.submit()">
                                    <option value="Просматривается" <%= order.status === 'Просматривается' ? 'selected' : '' %>>Просматривается</option>
                                    <option value="В очереди" <%= order.status === 'В очереди' ? 'selected' : '' %>>В очереди</option>
                                    <option value="Выполняется" <%= order.status === 'Выполняется' ? 'selected' : '' %>>Выполняется</option>
                                    <option value="Готов" <%= order.status === 'Готов' ? 'selected' : '' %>>Готов</option>
                                    <option value="Выполнен" <%= order.status === 'Выполнен' ? 'selected' : '' %>>Выполнен</option>
                                    <option value="Отменен" <%= order.status === 'Отменен' ? 'selected' : '' %>>Отменен</option>
                                </select>
                            </form>
                        </td>
                        <td>
                            <form action="/admin/order/<%= order.id %>/status" method="POST" style="display: inline;">
                                <input type="hidden" name="status" value="<%= order.status %>">
                                <input type="number" name="designer_id" value="<%= order.designer_id || '' %>" placeholder="ID дизайнера" style="width: 100px;">
                                <button type="submit" class="btn btn-small">OK</button>
                            </form>
                        </td>
                        <td>
                            <form action="/admin/order/<%= order.id %>/status" method="POST" style="display: inline;">
                                <input type="hidden" name="status" value="<%= order.status %>">
                                <input type="number" name="manager_id" value="<%= order.manager_id || '' %>" placeholder="ID менеджера" style="width: 100px;">
                                <button type="submit" class="btn btn-small">OK</button>
                            </form>
                        </td>
                        <td><%= new Date(order.created_at).toLocaleDateString('ru-RU') %></td>
                        <td><a href="/order/<%= order.id %>" class="btn btn-small" target="_blank">Просмотр</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
