<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Промокоды - Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-admin">
        <div class="nav-brand">NowkeArt Admin</div>
        <div class="nav-links">
            <a href="/admin">Главная</a>
            <a href="/admin/orders">Заказы</a>
            <a href="/admin/users">Пользователи</a>
            <a href="/admin/staff">Сотрудники</a>
            <a href="/admin/services">Услуги</a>
            <a href="/admin/promocodes">Промокоды</a>
            <a href="/admin/settings">Настройки</a>
            <a href="/dashboard">На сайт</a>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Управление промокодами</h1>
        
        <div class="card">
            <h2>Добавить промокод</h2>
            <form action="/admin/promocode/add" method="POST" class="inline-form">
                <div class="form-row">
                    <input type="text" name="promocode" placeholder="Код промокода" required>
                    <input type="number" name="sale" placeholder="Скидка (%)" step="0.1" required>
                    <button type="submit" class="btn btn-primary">Добавить</button>
                </div>
            </form>
        </div>

        <table class="promocodes-table">
            <thead>
                <tr>
                    <th>Промокод</th>
                    <th>Скидка</th>
                    <th>Использован раз</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% promocodes.forEach(promo => { %>
                    <tr>
                        <td><code><%= promo.promocode %></code></td>
                        <td><%= promo.sale %>%</td>
                        <td><%= promo.used_count %></td>
                        <td>
                            <form action="/admin/promocode/<%= encodeURIComponent(promo.promocode) %>/delete" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить промокод?')">Удалить</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
