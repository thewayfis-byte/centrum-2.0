<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Пользователи - Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-admin">
        <div class="nav-brand">NowkeArt Admin</div>
        <div class="nav-links">
            <a href="/admin">Главная</a>
            <a href="/admin/orders">Заказы</a>
            <a href="/admin/users">Пользователи</a>
            <a href="/admin/staff">Сотрудники</a>
            <a href="/admin/services">Услуги</a>
            <a href="/admin/promocodes">Промокоды</a>
            <a href="/admin/settings">Настройки</a>
            <a href="/dashboard">На сайт</a>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Управление пользователями</h1>
        
        <table class="users-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Имя пользователя</th>
                    <th>VK ID</th>
                    <th>Роль</th>
                    <th>Баланс</th>
                    <th>Заказов</th>
                    <th>Дата регистрации</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.user_id %></td>
                        <td><%= user.username %></td>
                        <td><%= user.vk_user_id || '-' %></td>
                        <td>
                            <form action="/admin/user/<%= user.user_id %>/role" method="POST" style="display: inline;">
                                <select name="role" onchange="this.form.submit()">
                                    <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>Пользователь</option>
                                    <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Админ</option>
                                    <option value="manager" <%= user.role === 'manager' ? 'selected' : '' %>>Менеджер</option>
                                </select>
                            </form>
                        </td>
                        <td><%= user.balance %> ₽</td>
                        <td><%= user.orders %></td>
                        <td><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                        <td>
                            <a href="/admin/user/<%= user.user_id %>" class="btn btn-small">Изменить</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
