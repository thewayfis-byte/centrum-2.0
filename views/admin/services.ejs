<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Услуги - Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-admin">
        <div class="nav-brand">NowkeArt Admin</div>
        <div class="nav-links">
            <a href="/admin">Главная</a>
            <a href="/admin/orders">Заказы</a>
            <a href="/admin/users">Пользователи</a>
            <a href="/admin/staff">Сотрудники</a>
            <a href="/admin/services">Услуги</a>
            <a href="/admin/promocodes">Промокоды</a>
            <a href="/admin/settings">Настройки</a>
            <a href="/dashboard">На сайт</a>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Управление услугами</h1>
        
        <div class="card">
            <h2>Добавить услугу</h2>
            <form action="/admin/service/add" method="POST" class="inline-form">
                <div class="form-row">
                    <input type="text" name="service" placeholder="Название услуги" required>
                    <input type="text" name="about" placeholder="Описание" required>
                    <input type="number" name="price" placeholder="Цена (₽)" value="0">
                    <input type="text" name="link" placeholder="Ссылка">
                    <input type="number" name="priority" placeholder="Приоритет" value="0">
                    <input type="text" name="alias" placeholder="Категория (alias)">
                    <button type="submit" class="btn btn-primary">Добавить</button>
                </div>
            </form>
        </div>

        <table class="services-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Цена</th>
                    <th>Категория</th>
                    <th>Приоритет</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% services.forEach(service => { %>
                    <tr>
                        <td><%= service.id %></td>
                        <td><%= service.service %></td>
                        <td><%= service.about.substring(0, 50) %><%= service.about.length > 50 ? '...' : '' %></td>
                        <td><%= service.price %> ₽</td>
                        <td><%= service.alias || '-' %></td>
                        <td><%= service.priority %></td>
                        <td>
                            <form action="/admin/service/<%= service.id %>/delete" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить услугу?')">Удалить</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
