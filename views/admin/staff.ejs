<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Сотрудники - Админ-панель</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-admin">
        <div class="nav-brand">NowkeArt Admin</div>
        <div class="nav-links">
            <a href="/admin">Главная</a>
            <a href="/admin/orders">Заказы</a>
            <a href="/admin/users">Пользователи</a>
            <a href="/admin/staff">Сотрудники</a>
            <a href="/admin/services">Услуги</a>
            <a href="/admin/promocodes">Промокоды</a>
            <a href="/admin/settings">Настройки</a>
            <a href="/dashboard">На сайт</a>
            <a href="/logout" class="logout-btn">Выход</a>
        </div>
    </nav>

    <div class="container">
        <h1>Управление сотрудниками</h1>
        
        <div class="card">
            <h2>Добавить сотрудника</h2>
            <form action="/admin/staff/add" method="POST" class="inline-form">
                <div class="form-row">
                    <input type="number" name="user_id" placeholder="VK User ID" required>
                    <input type="text" name="name" placeholder="Имя" required>
                    <select name="staff_group">
                        <option value="designer">Дизайнер</option>
                        <option value="manager">Менеджер</option>
                        <option value="admin">Админ</option>
                    </select>
                    <input type="text" name="perms" placeholder="Права (например: *)">
                    <button type="submit" class="btn btn-primary">Добавить</button>
                </div>
            </form>
        </div>

        <table class="staff-table">
            <thead>
                <tr>
                    <th>VK ID</th>
                    <th>Имя</th>
                    <th>Группа</th>
                    <th>Баланс</th>
                    <th>Рейтинг</th>
                    <th>Заказов выполнено</th>
                    <th>Права</th>
                    <th>Дизайнер</th>
                    <th>Менеджер</th>
                </tr>
            </thead>
            <tbody>
                <% staff.forEach(s => { %>
                    <tr>
                        <td><%= s.user_id %></td>
                        <td><%= s.name %></td>
                        <td><%= s.staff_group %></td>
                        <td><%= s.balance %> ₽</td>
                        <td><%= s.raything %> ⭐</td>
                        <td><%= s.orders_did %></td>
                        <td><code><%= s.perms || '-' %></code></td>
                        <td><%= s.can_work_designer ? '✓' : '✗' %></td>
                        <td><%= s.can_work_manager ? '✓' : '✗' %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
